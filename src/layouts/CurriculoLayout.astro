---
import "../styles/global.css";
import config from "../../docs/metadata/config.json";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = `Currículo — ${config.meta.title}`,
	description = config.meta.description,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="noindex, nofollow" />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content={config.name} />
	</head>
	<body class="bg-neutral-200 text-[#1a1a1a] min-h-screen py-10 px-5 print:bg-white print:p-0 print:m-0 font-sans">
		<!-- Print Button -->
		<button
			class="print:hidden fixed top-6 right-6 z-50 inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-sans text-sm font-semibold cursor-pointer shadow-[0_2px_8px_rgba(5,150,105,0.3)] hover:shadow-[0_4px_12px_rgba(5,150,105,0.4)] hover:-translate-y-0.5 transition-all duration-200"
			onclick="window.print()"
			aria-label="Imprimir currículo"
			id="cv-print-button"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<polyline points="6 9 6 2 18 2 18 9"></polyline>
				<path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
				<rect x="6" y="14" width="12" height="8"></rect>
			</svg>
			Imprimir
		</button>

		<slot />
	</body>
</html>
