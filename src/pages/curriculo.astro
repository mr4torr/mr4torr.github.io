---
import CurriculoLayout from "../layouts/CurriculoLayout.astro";
import config from "../../docs/metadata/config.json";
import experiences from "../../docs/metadata/experiences.json";
---

<CurriculoLayout>
  <main
    class="max-w-[210mm] mx-auto bg-white py-[48px] px-[52px] shadow-[0_1px_3px_rgba(0,0,0,0.08),0_8px_30px_rgba(0,0,0,0.12)] rounded-[2px] print:shadow-none print:m-0 print:p-0 print:max-w-full print:rounded-none"
    id="cv-page"
  >
    <!-- ===== HEADER / DADOS PESSOAIS ===== -->
    <header
      class="pb-5 border-b-2 border-emerald-600 mb-6 print:break-after-avoid"
    >
      <div class="flex gap-4 items-center">
        <img
          src="https://github.com/mr4torr.png"
          alt="Avatar"
          class="w-24 h-24 object-cover rounded-sm"
        />
        <div>
          <h1
            class="font-display font-extrabold text-[28px] text-[#111] mb-1 tracking-tight leading-[1.2]"
          >
            {config.meta.title}
          </h1>
          <p
            class="font-sans text-sm font-medium text-emerald-600 mb-4 tracking-wide"
          >
            {config.meta.description}
          </p>
          <div
            class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-[11.5px] text-neutral-600 leading-relaxed"
          >
            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path></svg
              >
              {config.contact.phone}
            </span>

            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                  d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
              >
              <a
                class="text-neutral-700 hover:text-emerald-600 hover:underline print:text-inherit print:no-underline"
                href={`mailto:${config.contact.email}`}
                >{config.contact.email}</a
              >
            </span>

            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
              {config.address}
            </span>

            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"
                ></path><path
                  d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                ></path></svg
              >
              <a
                class="text-neutral-700 hover:text-emerald-600 hover:underline print:text-inherit print:no-underline"
                href={`https://${config.contact.website}`}
                target="_blank"
                rel="noopener noreferrer">{config.contact.website}</a
              >
            </span>

            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              <a
                class="text-neutral-700 hover:text-emerald-600 hover:underline print:text-inherit print:no-underline"
                href={`https://${config.contact.github}`}
                target="_blank"
                rel="noopener noreferrer">{config.contact.github}</a
              >
            </span>

            <span class="inline-flex items-center gap-1 whitespace-nowrap">
              <svg
                class="text-emerald-600 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
              <a
                class="text-neutral-700 hover:text-emerald-600 hover:underline print:text-inherit print:no-underline"
                href={`https://${config.contact.linkedin}`}
                target="_blank"
                rel="noopener noreferrer">{config.contact.linkedin}</a
              >
            </span>
          </div>
        </div>
      </div>
    </header>

    <!-- ===== RESUMO PROFISSIONAL ===== -->
    <section
      class="mb-[22px] last:mb-0 print:break-inside-avoid"
      id="cv-resumo"
    >
      <h2
        class="font-display font-bold text-[15px] text-emerald-600 uppercase mb-2.5 pb-1.5 border-b border-neutral-200 print:break-after-avoid"
      >
        Resumo Profissional
      </h2>
      <p class="text-[12.5px] leading-relaxed text-[#333] m-0 text-justify">
        {config.preview}
      </p>
    </section>

    <!-- ===== EXPERIÊNCIA PROFISSIONAL ===== -->
    <section
      class="mb-[22px] last:mb-0 print:break-inside-avoid"
      id="cv-experiencia"
    >
      <h2
        class="font-display font-bold text-[15px] text-emerald-600 uppercase tracking-widest mb-2.5 pb-1.5 border-b border-neutral-200 print:break-after-avoid"
      >
        Experiência Profissional
      </h2>

      <div class="flex flex-col gap-4">
        {
          experiences.map((exp) => (
            <div class="pl-3.5 border-l-2 border-neutral-200 print:break-inside-avoid">
              <div class="flex justify-between items-start gap-4 mb-1.5">
                <div>
                  <h3 class="font-display font-bold text-[13.5px] text-[#111] m-0 leading-[1.35]">
                    {exp.title}:{" "}
                    <span class="text-xs text-neutral-500 font-medium">
                      {exp.company}
                    </span>
                  </h3>
                </div>
                <span class="text-[11px] text-neutral-400 font-medium whitespace-nowrap shrink-0 pt-0.5">
                  {exp.period}
                </span>
              </div>
              <p class="text-xs leading-relaxed text-[#444] m-0 text-justify">
                {exp.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ===== ESPECIALIZAÇÕES & CURSOS ===== -->
    <section
      class="mb-[22px] last:mb-0 print:break-inside-avoid"
      id="cv-cursos"
    >
      <h2
        class="font-display font-bold text-[15px] text-emerald-600 uppercase tracking-widest mb-2.5 pb-1.5 border-b border-neutral-200 print:break-after-avoid"
      >
        Especializações e Cursos
      </h2>
      <p class="text-[12.5px] leading-relaxed text-[#333] m-0 text-justify">
        {config.courses}
      </p>
    </section>
  </main>
</CurriculoLayout>
