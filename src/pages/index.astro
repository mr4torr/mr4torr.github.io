          </button>
        ))}
      </div>

      <!-- Grid of Projects -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
        {categories.map((cat) => {
          const categorySlug = cat.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
          return cat.projects.map((proj) => (
            <div class="project-card bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200 dark:border-neutral-700/70 p-6 flex flex-col justify-between transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg" data-category={categorySlug}>
              <div>
                <div class="flex items-center justify-between mb-4">
                  <span class="text-3xl" role="img" aria-label="emoji">{proj.emoji}</span>
                  <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700">
                    {cat.name}
                  </span>
                </div>
                <h3 class="font-display font-bold text-lg text-neutral-900 dark:text-white mb-2 leading-snug hover:text-emerald-500 dark:hover:text-emerald-450 transition-colors">
                  {proj.name}
                </h3>
                <p class="text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed mb-6">
                  {proj.description}
                </p>
              </div>

              <div>
                <!-- Technologies -->
                <div class="flex flex-wrap gap-1.5 mb-6">
                  {proj.technologies.slice(0, 5).map((tech) => (
                    <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded bg-neutral-50 dark:bg-neutral-800 text-[10px] text-neutral-500 dark:text-neutral-400 font-semibold border border-neutral-100 dark:border-neutral-700/70">
                      {tech}
                    </span>
                  ))}
                  {proj.technologies.length > 5 && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-[10px] text-neutral-500 dark:text-neutral-400 font-semibold">
                      +{proj.technologies.length - 5}
                    </span>
                  )}
                </div>

                <!-- GitHub Link -->
                <a href={proj.link} target="_blank" rel="noopener noreferrer" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-neutral-200 dark:border-neutral-800 hover:border-emerald-500 dark:hover:border-emerald-450 hover:text-emerald-500 dark:hover:text-emerald-400 font-semibold text-sm text-neutral-700 dark:text-neutral-300 transition-all duration-200 bg-neutral-50/50 dark:bg-neutral-950/40">
                  <TechIcon name="github" class="w-4 h-4" />
                  Acessar Repositório
                  <TechIcon name="external" class="w-3 h-3 text-neutral-400 dark:text-neutral-500" />
                </a>
              </div>
            </div>
          ));
        })}
      </div>
    </div>
  </section>

  <!-- Contact Section (Seção de Contato Direto) -->
  <section id="contact" class="py-20 md:py-28 bg-neutral-50 dark:bg-neutral-900/40 border-t border-neutral-100 dark:border-neutral-900 relative overflow-hidden transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-emerald-500 dark:text-emerald-400 font-display font-bold uppercase tracking-wider text-sm">Entre em Contato</span>
        <h2 class="font-display font-extrabold text-3xl md:text-4xl text-neutral-900 dark:text-white mt-2 mb-4">
