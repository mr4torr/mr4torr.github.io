                      ))}
                    </div>
                  </div>
                </div>

                <!-- Spacer on desktop to align properly -->
                <div class="hidden sm:block w-1/2"></div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section (GitHub Projects) -->
  <section id="projects" class="py-20 md:py-28 bg-white dark:bg-neutral-950 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-emerald-500 dark:text-emerald-400 font-display font-bold uppercase tracking-wider text-sm">Projetos & Portfólio</span>
        <h2 class="font-display font-extrabold text-3xl md:text-4xl text-neutral-900 dark:text-white mt-2 mb-4">
          Estudos Técnicos & Open Source
        </h2>
        <p class="text-neutral-500 dark:text-neutral-400">
          Projetos autorais e laboratórios práticos disponíveis no meu GitHub. Use as abas abaixo para filtrar por tecnologia ou finalidade.
        </p>
      </div>

      <!-- Filters (Dynamic JavaScript Tabs) -->
      <div class="flex flex-wrap justify-center gap-2 mb-12" id="project-filters">
        <button class="px-5 py-2 rounded-full text-sm font-semibold border filter-btn active-filter" data-filter="all">
          Todos os Projetos
