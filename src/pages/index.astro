      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <!-- Email CTA -->
        <a href={`mailto:${config.contact.email}`} class="bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 text-center hover:border-emerald-300 dark:hover:border-emerald-800 hover:shadow-lg transition-all duration-300 group flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-emerald-50 dark:bg-emerald-950/30 text-emerald-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
