---
import Layout from '../layouts/Layout.astro';
import TechIcon from '../components/TechIcon.astro';
import config from '../../docs/metadata/config.json';
import experiences from '../../docs/metadata/experiences.json';
import fs from 'node:fs';
import path from 'node:path';

// Parsing projects.md at build time
const projectsFilePath = path.join(process.cwd(), 'docs', 'projects.md');
let categories = [];

try {
  const projectsContent = fs.readFileSync(projectsFilePath, 'utf-8');
  const sections = projectsContent.split('###');

  for (const section of sections) {
    const trimmedSection = section.trim();
    if (!trimmedSection) continue;

    const lines = trimmedSection.split('\n');
    const headerLine = lines[0].trim();
    if (headerLine.includes('📋') || headerLine.includes('Stack de Tecnologias')) {
      continue;
    }

    // Category name
    const categoryName = headerLine.replace(/\*\*/g, '').trim();

    // Split projects by number format: \n1. **
    const projectBlocks = trimmedSection.split(/\n\d+\.\s+\*\*/);
    const projects = [];

    for (let i = 1; i < projectBlocks.length; i++) {
      const block = projectBlocks[i];
      const blockLines = block.split('\n');

      const titleLine = blockLines[0].trim();
      const name = titleLine.split('**')[0].trim();

      // Emoji extraction
      const emojiMatch = titleLine.match(/[\u{1F300}-\u{1F6FF}\u{1F900}-\u{1F9FF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}]/u);
      const emoji = emojiMatch ? emojiMatch[0] : '💻';

      let description = '';
      let technologies = [];
      let link = '';

      for (const line of blockLines) {
        const trimmedLine = line.trim();
        if (trimmedLine.includes('Descrição:')) {
          description = trimmedLine.split('Descrição:')[1].trim();
        } else if (trimmedLine.includes('Tecnologias:')) {
          technologies = trimmedLine.split('Tecnologias:')[1].trim().split(',').map(t => t.trim());
        } else if (trimmedLine.includes('Link:')) {
          link = trimmedLine.split('Link:')[1].trim();
        }
      }

      projects.push({
        name,
        emoji,
        description,
        technologies,
        link
      });
    }

    if (projects.length > 0) {
      categories.push({
        name: categoryName,
        projects
      });
    }
  }
} catch (e) {
  console.error("Erro ao ler ou processar projects.md:", e);
}

---

<Layout>
  <!-- Header (Navbar) -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/70 dark:bg-neutral-950/85 backdrop-blur-sm border-b border-neutral-100 dark:border-neutral-900 transition-all duration-300" id="main-header">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="#" class="font-display font-bold text-xl text-neutral-900 dark:text-white tracking-tight flex items-center gap-2 group">
        <span class="text-emerald-500 font-extrabold group-hover:rotate-12 transition-transform duration-300">&lt;/&gt;</span>
        <span>{config.nickname}</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8 font-medium text-neutral-600 dark:text-neutral-300">
        <a href="#about" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Sobre</a>
        <a href="#skills" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Habilidades</a>
        <a href="#experience" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Experiência</a>
        <a href="#projects" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Projetos</a>
        <a href="#contact" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Contato</a>
        <a href="/curriculo" class="text-orange-500 dark:hover:text-emerald-400 transition-colors">Currículo</a>
      </nav>

      <!-- CTA, Theme Toggle and Socials -->
      <div class="hidden md:flex items-center gap-4">
        <a href={config.social.github} target="_blank" rel="noopener noreferrer" class="text-neutral-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors" aria-label="GitHub">
          <TechIcon name="github" class="w-6 h-6" />
        </a>
        <a href={config.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors" aria-label="LinkedIn">
          <TechIcon name="linkedin" class="w-6 h-6" />
        </a>

        <!-- Botão Toggle de Tema (Desktop) -->
        <button id="theme-toggle" class="p-2.5 rounded-full text-neutral-600 dark:text-neutral-300 hover:text-emerald-500 dark:hover:text-emerald-400 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors focus:outline-none" aria-label="Alternar Tema">
          <!-- Moon Icon -->
          <svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
          <!-- Sun Icon -->
          <svg id="theme-toggle-light-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.46 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
          </svg>
        </button>

        <a href="#contact" class="bg-emerald-500 hover:bg-emerald-600 text-white font-semibold px-5 py-2.5 rounded-full shadow-sm hover:shadow-md transition-colors duration-300">
          Fale Comigo
        </a>
      </div>

      <!-- Mobile Menu Button & Toggle Combo -->
      <div class="flex items-center gap-2 md:hidden">
        <!-- Botão Toggle de Tema (Mobile Header) -->
        <button id="theme-toggle-header-mobile" class="p-2.5 rounded-full text-neutral-600 dark:text-neutral-300 hover:text-emerald-500 dark:hover:text-emerald-400 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors focus:outline-none" aria-label="Alternar Tema">
          <svg id="theme-toggle-dark-icon-hm" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
          <svg id="theme-toggle-light-icon-hm" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.46 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
          </svg>
        </button>

        <button class="p-2 text-neutral-600 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-white focus:outline-none" id="mobile-menu-btn" aria-label="Abrir Menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation Drawer -->
    <div class="hidden md:hidden bg-white dark:bg-neutral-950 border-b border-neutral-100 dark:border-neutral-900 px-6 py-4 transition-all duration-300" id="mobile-nav">
      <nav class="flex flex-col gap-4 font-medium text-neutral-600 dark:text-neutral-300">
        <a href="#about" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors py-2">Sobre</a>
        <a href="#skills" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors py-2">Habilidades</a>
        <a href="#experience" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors py-2">Experiência</a>
        <a href="#projects" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors py-2">Projetos</a>
        <a href="#contact" class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors py-2">Contato</a>
        <div class="flex items-center gap-4 pt-4 border-t border-neutral-100 dark:border-neutral-900">
          <a href={config.social.github} target="_blank" rel="noopener noreferrer" class="text-neutral-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors" aria-label="GitHub">
            <TechIcon name="github" class="w-6 h-6" />
          </a>
          <a href={config.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors" aria-label="LinkedIn">
            <TechIcon name="linkedin" class="w-6 h-6" />
          </a>
          <a href="#contact" class="bg-emerald-500 hover:bg-emerald-600 text-white font-semibold px-4 py-2 rounded-full text-center flex-1">
            Fale Comigo
          </a>
        </div>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-24 md:pt-40 md:pb-36 bg-white dark:bg-neutral-950 overflow-hidden bg-grid-pattern transition-colors duration-300">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 dark:via-neutral-950/50 to-white dark:to-neutral-950"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex flex-col md:flex-row-reverse items-center justify-between gap-12">
        <!-- Avatar Profile -->
        <div class="relative w-48 h-48 md:w-72 md:h-72 flex-shrink-0 animate-fade-in">
          <div class="absolute inset-0 bg-gradient-to-tr from-emerald-500 to-amber-400 blur-2xl opacity-20 dark:opacity-10 scale-105"></div>
          <div class="relative w-full h-full p-2 bg-gradient-to-tr from-neutral-100 dark:from-neutral-900 via-white dark:via-neutral-950 to-emerald-100 dark:to-emerald-950 shadow-xl border border-neutral-100 dark:border-neutral-800">
            <img
              src="https://github.com/mr4torr.png"
              alt={config.name}
              class="w-full h-full object-cover bg-neutral-100 dark:bg-neutral-900"
              loading="eager"
            />
          </div>
        </div>

        <!-- Hero Content -->
        <div class="flex-1 text-center md:text-left max-w-2xl">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-55 dark:bg-emerald-950/50 text-emerald-600 dark:text-emerald-400 mb-6 border border-emerald-100 dark:border-emerald-900/60">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
            Atualizado em 2026
          </span>
          <h1 class="font-display font-extrabold text-4xl md:text-6xl text-neutral-900 dark:text-white tracking-tight leading-none mb-6">
            {config.name}
          </h1>
          <p class="font-display text-lg md:text-2xl text-emerald-500 dark:text-emerald-400 font-semibold mb-6">
            {config.meta.description}
          </p>
          <p class="text-neutral-600 dark:text-neutral-300 text-base md:text-lg leading-relaxed mb-8">
            {config.preview}
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4">
            <a href="#projects" class="w-full sm:w-auto bg-neutral-900 dark:bg-neutral-100 hover:bg-neutral-800 dark:hover:bg-white text-white dark:text-neutral-950 font-semibold px-8 py-3.5 rounded-full shadow-md hover:shadow-lg transition-all duration-300 text-center flex items-center justify-center gap-2">
              <TechIcon name="code" class="w-5 h-5 text-emerald-500 dark:text-emerald-600" />
              Ver Projetos GitHub
            </a>
            <a href="#contact" class="w-full sm:w-auto border-2 border-neutral-200 dark:border-neutral-800 hover:border-emerald-500 dark:hover:border-emerald-400 text-neutral-700 dark:text-neutral-300 hover:text-emerald-500 dark:hover:text-emerald-400 font-semibold px-8 py-3.5 rounded-full transition-all duration-300 text-center flex items-center justify-center gap-2">
              <TechIcon name="email" class="w-5 h-5" />
              Entrar em Contato
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About / Identity Section -->
  <section id="about" class="py-20 md:py-28 bg-neutral-50 dark:bg-neutral-900/40 border-t border-b border-neutral-100 dark:border-neutral-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Text Content -->
        <div class="lg:col-span-7">
          <span class="text-emerald-500 dark:text-emerald-400 font-display font-bold uppercase tracking-wider text-sm">Sobre Mim</span>
          <h2 class="font-display font-extrabold text-3xl md:text-4xl text-neutral-900 dark:text-white mt-2 mb-6 leading-tight">
            Ajudei a construir ecossistemas digitais com excelência
          </h2>
          <div class="space-y-4 text-neutral-600 dark:text-neutral-300 leading-relaxed text-base">
            <p>
              Com mais de uma década de experiência no desenvolvimento de software, atuo desenhando e implementando sistemas distribuídos de alta performance, arquiteturas SaaS robustas e ferramentas que facilitam o dia a dia do desenvolvimento.
            </p>
            <p>
              Como referência técnica na <strong>SoftExpert</strong>, lidero a inovação e modernização de stacks, além de modelar estruturas modulares baseadas em arquiteturas limpas (Clean Architecture, DDD). Acredito na simplicidade, automação e em manter a qualidade da base de código como prioridades para times de alto desempenho.
            </p>
          </div>
        </div>

        <!-- Right Metrics Visuals -->
        <div class="lg:col-span-5 grid grid-cols-2 gap-4">
          <div class="bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 text-center lg:text-left transition-all hover:-translate-y-1 hover:shadow-md duration-300">
            <span class="block font-display font-extrabold text-4xl md:text-5xl text-emerald-500 dark:text-emerald-400 mb-2">15+</span>
            <span class="block text-neutral-500 dark:text-neutral-400 text-sm font-semibold uppercase tracking-wider">Anos de Experiência</span>
            <span class="block text-neutral-400 dark:text-neutral-500 text-xs mt-1">Carreira sólida em tech</span>
          </div>
          <div class="bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 text-center lg:text-left transition-all hover:-translate-y-1 hover:shadow-md duration-300">
            <span class="block font-display font-extrabold text-4xl md:text-5xl text-neutral-900 dark:text-white mb-2">200+</span>
            <span class="block text-neutral-500 dark:text-neutral-400 text-sm font-semibold uppercase tracking-wider">Devs Impactados</span>
            <span class="block text-neutral-400 dark:text-neutral-500 text-xs mt-1">Abstrações e ferramentas</span>
          </div>

          <div class="col-span-2">
            <div class="flex flex-wrap gap-3 mt-4 justify-center lg:justify-start">
              <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-sm bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium">
                <TechIcon name="check" class="w-4 h-4 text-green-500" /> SaaS Multi-Tenant
              </span>
              <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-sm bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium">
                <TechIcon name="check" class="w-4 h-4 text-green-500" /> Clean Architecture
              </span>
              <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-sm bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium">
                <TechIcon name="check" class="w-4 h-4 text-green-500" /> Tooling & DX
              </span>
              <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-sm bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium">
                <TechIcon name="check" class="w-4 h-4 text-green-500" /> AppSec / Segurança
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="py-20 md:py-28 bg-white dark:bg-neutral-950 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-emerald-500 dark:text-emerald-400 font-display font-bold uppercase tracking-wider text-sm">Habilidades Técnicas</span>
        <h2 class="font-display font-extrabold text-3xl md:text-4xl text-neutral-900 dark:text-white mt-2 mb-4">
          Grade de Competências & Especialidades
        </h2>
        <p class="text-neutral-500 dark:text-neutral-400">
          Tecnologias e metodologias que domino e aplico para construir sistemas robustos e eficientes.
        </p>
      </div>

      <div class="space-y-12">
        <!-- Domínio Forte -->
        <div>
          <div class="flex items-center gap-2.5 mb-6 pb-2 border-b border-neutral-100 dark:border-neutral-900">
            <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
            <h3 class="font-display font-bold text-lg text-neutral-900 dark:text-white">Especialidade / Domínio Forte</h3>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {config.skills.strong.map((skill) => (
              <div class="flex items-center gap-3 p-4 bg-neutral-50 dark:bg-neutral-900/60 rounded-xl border border-neutral-100 dark:border-neutral-900 hover:border-emerald-300 dark:hover:border-emerald-800 hover:bg-emerald-50/20 dark:hover:bg-emerald-950/10 transition-all duration-200 group">
                <div class="text-neutral-600 dark:text-neutral-400 group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors flex-shrink-0">
                  <TechIcon name={skill} className="w-6 h-6" />
                </div>
                <span class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 leading-tight">{skill}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Domínio Intermediário -->
        <div>
          <div class="flex items-center gap-2.5 mb-6 pb-2 border-b border-neutral-100 dark:border-neutral-900">
            <span class="w-3 h-3 rounded-full bg-amber-500"></span>
            <h3 class="font-display font-bold text-lg text-neutral-900 dark:text-white">Proficiência / Domínio Médio</h3>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {config.skills.middle.map((skill) => (
              <div class="flex items-center gap-3 p-4 bg-neutral-50 dark:bg-neutral-900/60 rounded-xl border border-neutral-100 dark:border-neutral-900 hover:border-amber-200 dark:hover:border-amber-800 hover:bg-amber-50/20 dark:hover:bg-amber-950/10 transition-all duration-200 group">
                <div class="text-neutral-500 dark:text-neutral-400 group-hover:text-amber-600 dark:group-hover:text-amber-500 transition-colors flex-shrink-0">
                  <TechIcon name={skill} className="w-5 h-5" />
                </div>
                <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300 leading-tight">{skill}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Conhecimentos -->
        <div>
          <div class="flex items-center gap-2.5 mb-6 pb-2 border-b border-neutral-100 dark:border-neutral-900">
            <span class="w-3 h-3 rounded-full bg-indigo-400"></span>
            <h3 class="font-display font-bold text-lg text-neutral-900 dark:text-white">Outros Conhecimentos / Estudos</h3>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {config.skills.small.map((skill) => (
              <div class="flex items-center gap-3 p-4 bg-neutral-50 dark:bg-neutral-900/60 rounded-xl border border-neutral-100 dark:border-neutral-900 hover:border-indigo-300 dark:hover:border-indigo-700 hover:bg-indigo-50/20 dark:hover:bg-indigo-950/10 transition-all duration-200 group">
                <div class="text-neutral-400 dark:text-neutral-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-300 transition-colors flex-shrink-0">
                  <TechIcon name={skill} className="w-5 h-5" />
                </div>
                <span class="text-sm text-neutral-600 dark:text-neutral-400 leading-tight">{skill}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section (Experiences) -->
  <section id="experience" class="py-20 md:py-28 bg-neutral-50 dark:bg-neutral-900/40 border-t border-b border-neutral-100 dark:border-neutral-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-emerald-500 dark:text-emerald-400 font-display font-bold uppercase tracking-wider text-sm">Histórico Profissional</span>
        <h2 class="font-display font-extrabold text-3xl md:text-4xl text-neutral-900 dark:text-white mt-2 mb-4">
          Minha jornada como desenvolvedor
        </h2>
        <p class="text-neutral-500 dark:text-neutral-400">
          Evolução como desenvolvedor de software até o momento.
        </p>
      </div>

      <!-- Vertical Timeline Structure -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Central Line for timeline -->
        <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-0.5 bg-neutral-200 dark:bg-neutral-800 transform -translate-x-1/2"></div>

        <div class="space-y-12">
          {experiences.map((exp, index) => {
            const isLeft = index % 2 === 0;
            return (
              <div class={`relative flex flex-col sm:flex-row items-stretch ${isLeft ? 'sm:flex-row-reverse' : ''}`}>
                <!-- Timeline Dot -->
