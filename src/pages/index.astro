                  <div class="bg-white dark:bg-neutral-900 p-6 md:p-8 rounded-3xl border border-neutral-200/70 dark:border-neutral-700/70 hover:border-emerald-500 hover:ring-4 hover:ring-emerald-500/10 transition-all duration-300">
