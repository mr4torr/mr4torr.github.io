                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-neutral-50 dark:bg-neutral-800 text-xs text-neutral-600 dark:text-neutral-400 border border-neutral-200/60 dark:border-neutral-700 font-medium">
                          <TechIcon name={skill} class="w-3 h-3 text-neutral-400" />
