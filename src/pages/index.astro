          <p class="text-neutral-500 dark:text-neutral-400 text-sm mb-4 leading-relaxed">Envie propostas, documentações ou convites corporativos.</p>
          <span class="text-emerald-500 dark:text-emerald-400 font-semibold text-sm inline-flex items-center gap-1">
            {config.contact.email} <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
          </span>
        </a>

        <!-- LinkedIn CTA -->
        <a href={config.social.linkedin} target="_blank" rel="noopener noreferrer" class="bg-white dark:bg-neutral-900 p-8 rounded-2xl border border-neutral-200 dark:border-neutral-800 text-center hover:border-blue-300 dark:hover:border-blue-800 hover:shadow-lg transition-all duration-300 group flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-blue-50 dark:bg-blue-950/30 text-blue-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <TechIcon name="linkedin" class="w-6 h-6" />
          </div>
          <h3 class="font-display font-bold text-lg text-neutral-900 dark:text-white mb-2">Conectar no LinkedIn</h3>
          <p class="text-neutral-500 dark:text-neutral-400 text-sm mb-4 leading-relaxed">Conecte-se à minha rede profissional e veja minhas publicações.</p>
          <span class="text-blue-600 dark:text-blue-400 font-semibold text-sm inline-flex items-center gap-1">
            Ver perfil profissional <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
