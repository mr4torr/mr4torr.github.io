          <p class="text-neutral-400 text-sm leading-relaxed mb-6 max-w-sm">
            {config.name} é Arquiteto de Software e Tech Lead dedicado a prover estruturas robustas e de alto desempenho no ecossistema web moderno.
          </p>
          <!-- Contatos e Endereço -->
          <div class="space-y-2 text-sm text-neutral-400">
            <div class="flex items-center gap-2">
              <TechIcon name="map" class="w-4 h-4 text-neutral-500" />
