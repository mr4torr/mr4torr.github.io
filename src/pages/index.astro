            <div class="flex items-center gap-2">
              <TechIcon name="email" class="w-4 h-4 text-neutral-500" />
              <a href={`mailto:${config.contact.email}`} class="hover:text-white transition-colors">{config.contact.email}</a>
            </div>
          </div>
        </div>

        <!-- Academic and Courses -->
        <div class="lg:col-span-7">

          <!-- Extra Courses -->
          <div>
            <h3 class="text-white font-display font-semibold text-base uppercase tracking-wider mb-4 flex items-center gap-2">
              <TechIcon name="calendar" class="w-5 h-5 text-emerald-500" />
              Especializações
            </h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              {config.courses}
